{
  "name": "vscope",
  "version": "0.0.1",
  "description": "Local daemon + Foldkit UI for the vscope embedded debug interface",
  "keywords": [
    "debug",
    "embedded",
    "mcp",
    "oscilloscope",
    "serial"
  ],
  "homepage": "https://github.com/tomrford/vscope#readme",
  "bugs": {
    "url": "https://github.com/tomrford/vscope/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomrford/vscope.git"
  },
  "bin": {
    "vscope": "bin/vscope.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md",
    "LICENSE.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:runtime": "vite build --config packages/runtime/vite.config.ts",
    "build:ui": "pnpm --filter @vscope/ui build",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build:runtime && pnpm run build:ui && pnpm run format:check && node bin/vscope.js --help > /dev/null && node bin/vscope.js --version > /dev/null",
    "dev:ui": "pnpm --filter @vscope/ui dev",
    "effect:diagnostics": "effect-language-service diagnostics --project tsconfig.json --format text",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --deny-warnings --no-error-on-unmatched-pattern && pnpm run effect:diagnostics",
    "pack:dry": "pnpm pack --dry-run",
    "prepublishOnly": "pnpm run check && pnpm run pack:dry",
    "test": "pnpm -r test",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/platform-browser": "4.0.0-beta.78",
    "@effect/platform-node": "4.0.0-beta.78",
    "@effect/sql-sqlite-node": "4.0.0-beta.78",
    "effect": "4.0.0-beta.78",
    "foldkit": "0.106.0",
    "serialport": "13.0.0"
  },
  "devDependencies": {
    "@effect/language-service": "0.86.2",
    "@foldkit/devtools-mcp": "0.10.0",
    "@foldkit/vite-plugin": "0.8.0",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.1"
}
