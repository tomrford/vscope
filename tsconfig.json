{
  "$schema": "./node_modules/@effect/language-service/schema.json",
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@vscope/liveplot": ["packages/liveplot/src/index.ts"],
      "@vscope/liveplot/*": ["packages/liveplot/src/*"],
      "@vscope/persistence": ["packages/persistence/src/index.ts"],
      "@vscope/runtime": ["packages/runtime/src/index.ts"],
      "@vscope/serial": ["packages/serial/src/index.ts"],
      "@vscope/shared": ["packages/shared/src/index.ts"]
    },
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  },
  "include": ["packages/**/*.ts", "src/**/*.ts"],
  "exclude": ["node_modules", "dist", "out", "grepo", "reference"]
}
